# Telegram
BOT_TOKEN=123456789:REPLACE_WITH_BOT_TOKEN
BOT_USERNAME=your_test_bot
ADMIN_IDS=123456789
ADMIN_USERNAME=your_admin_username
WEBHOOK_SECRET=replace-with-a-long-random-secret

# Public URL. Domain connected to Render, without trailing slash.
WEBAPP_URL=https://app.example.uz

# Security
SECRET_KEY=replace-with-a-random-64-character-secret
ACCESS_TOKEN_MINUTES=1440
ADMIN_TOKEN_HOURS=8
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# Database
# Local development:
DATABASE_URL=sqlite:///./data/app.db
# Render production example (recommended persistent PostgreSQL):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Initial admin panel account (created automatically if it does not exist)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe_12345

# HTTP / CORS
ALLOWED_ORIGINS=https://app.example.uz
TRUSTED_HOSTS=app.example.uz,*.onrender.com,localhost,127.0.0.1
MAX_UPLOAD_MB=20
RATE_LIMIT_PER_MINUTE=60

# Development only. Keep false on Render.
DEBUG=false
ENABLE_DEV_AUTH=false
DEV_TELEGRAM_ID=999000111
